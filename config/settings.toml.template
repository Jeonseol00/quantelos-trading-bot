# =============================================================================
# Quantelos AI Trader — Master Configuration Template
# =============================================================================
# Copy this file to config/settings.toml and fill in your credentials.
# =============================================================================

[project]
name    = "Quantelos AI Trader"
version = "1.0.0"
mode    = "DEMO"  # "DEMO" | "LIVE"
owner   = "Muhamad Fikri"

# ─── OANDA Broker Configuration ──────────────────────────────────────────────
[oanda]
api_url        = "https://api-fxpractice.oanda.com"
account_id     = "YOUR_OANDA_ACCOUNT_ID"
api_token      = "YOUR_OANDA_API_TOKEN"
stream_url     = "https://stream-fxpractice.oanda.com"
instruments    = ["XAU_USD"]

# ─── Capital & Risk Parameters (BRD-Locked) ──────────────────────────────────
[risk]
initial_capital_usc   = 12000000  # Scaled to live practice size (100,000 SGD)
max_drawdown_pct      = 0.15      # 15% MDD limit
risk_per_trade_pct    = 0.002     # Calibrated to 0.2% risk per trade for stability
min_risk_reward_ratio = 1.0       # Scalping allows 1:1 risk-reward
max_slippage_pips     = 2.0       # Cancel order if slippage > 2 pips
max_open_positions    = 2         # Maximum concurrent positions
whipsaw_freeze_sec    = 1800      # 30-minute freeze after fakeout detection

# ─── ZeroMQ IPC Configuration ────────────────────────────────────────────────
[zmq]
protocol   = "ipc"                          # "ipc" (recommended) | "tcp"
ipc_path   = "/tmp/quantelos_ipc.sock"      # Unix domain socket path
tcp_addr   = "tcp://127.0.0.1:5555"         # Fallback TCP loopback
timeout_ms = 5000                            # Subscriber poll timeout

# ─── Database Configuration ──────────────────────────────────────────────────
[database]
path         = "./data/quantelos.db"
journal_mode = "WAL"
busy_timeout = 5000

# ─── Technical Analysis Parameters (MRD-Locked) ──────────────────────────────
[strategy]
name             = "QUANTITATIVE_SNIPER"
timeframe        = "M5"              # Scalping runs on M5 execution timeframe
active_mode      = "MTF_SCALPER"     # "QUANTITATIVE_SNIPER" | "MTF_SCALPER"
atr_period       = 14
atr_squeeze_threshold_pips = 80.0   # Below this = squeeze detected
bollinger_period = 20
bollinger_std    = 2.0
bollinger_bandwidth_percentile = 25  # Bandwidth < 25th percentile of 20-day history
rsi_period       = 14
rsi_neutral_low  = 40
rsi_neutral_high = 60
scalping_rsi_low = 42                # Relaxed from 35 to increase entry probability
scalping_rsi_high = 58               # Relaxed from 65 to increase entry probability
scalping_vwap_std = 1.3              # Reduced from 1.5 to make Keltner Channels narrower
scalping_trend_filter = false
scalping_stop_pips = 12.0
scalping_target_pips = 12.0
scalping_atr_tp_mult = 1.0           # Tighter target to secure profit quickly (1.0x ATR)
scalping_atr_sl_mult = 1.0           # 1.0x ATR stop loss to maintain 1:1 risk-reward
allow_asia_scalping = true

# ─── Market Time Windows (MRD-Locked, WIB / UTC+7) ───────────────────────────
[market_windows]
midnight_block_start = "04:00"    # Hard block: NO new positions
midnight_block_end   = "05:15"
asia_session_start   = "05:00"    # Passive monitoring mode
asia_session_end     = "13:00"
london_session_start = "13:00"    # Active monitoring
london_session_end   = "17:00"
golden_window_start  = "19:00"    # HIGH ALERT execution window
golden_window_end    = "22:00"

# ─── Kaggle AI Brain Configuration ───────────────────────────────────────────
[kaggle]
sync_method     = "manual"       # "supabase" | "github_gist" | "manual"
supabase_url    = "YOUR_SUPABASE_URL"
supabase_key    = "YOUR_SUPABASE_SERVICE_ROLE_KEY"
gist_id         = ""
poll_interval_s = 30               # How often ASUS checks for new Kaggle URL
inference_timeout_s = 15           # Max wait for LLM response
fallback_model  = "vader"          # Local fallback: "vader" | "distilbert"

# ─── Notification Channels ───────────────────────────────────────────────────
[notifications]
enabled        = true
discord_webhook = "YOUR_DISCORD_WEBHOOK_URL"
telegram_bot_token = "YOUR_TELEGRAM_BOT_TOKEN"
telegram_chat_id   = "YOUR_TELEGRAM_CHAT_ID"
alert_on_trade     = true
alert_on_error     = true
alert_on_heartbeat_fail = true

# ─── Scraper Configuration ───────────────────────────────────────────────────
[scraper]
layer1_timeout_ms     = 200       # HTTP client max latency
layer2_enabled        = true      # Playwright Stealth fallback
layer2_max_ram_mb     = 400       # cgroup RAM limit for Playwright
layer3_enabled        = false     # CloakBrowser (manual enable only)
layer3_max_ram_mb     = 500       # cgroup RAM limit for CloakBrowser
force_kill_after_s    = 30        # Kill browser process after extraction
sources               = ["forex_factory", "investing_com", "financial_juice"]

# ─── Logging ──────────────────────────────────────────────────────────────────
[logging]
level      = "INFO"               # "DEBUG" | "INFO" | "WARNING" | "ERROR"
log_file   = "./logs/quantelos.log"
max_size_mb = 50
rotate     = true
