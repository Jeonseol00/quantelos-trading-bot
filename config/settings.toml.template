[project]
name    = "Quantelos AI Trader"
version = "1.0.0"
mode    = "DEMO"  # "DEMO" | "LIVE"
owner   = "Muhamad Fikri"

# ─── OANDA Broker Configuration ──────────────────────────────────────────────
# REGIONAL DIVISION: OANDA Asia Pacific (migrated from BVI — REST v20 API blocked on BVI)
[oanda]
api_url        = "https://api-fxpractice.oanda.com"   # Demo endpoint (Asia Pacific)
# api_url      = "https://api-fxtrade.oanda.com"      # Live endpoint (DO NOT USE UNTIL APPROVED)
account_id     = "101-003-39529667-001"                 # OANDA Asia Pacific Demo Account
api_token      = "267d6e61673dc9f99b78366c41255e52-980c7867af1f51b709aa9ddd1546956a"
stream_url     = "https://stream-fxpractice.oanda.com"
instruments    = ["XAU_USD"]

# ─── Capital & Risk Parameters (BRD-Locked) ──────────────────────────────────
[risk]
initial_capital_usc   = 12000000  # Scaled to live practice size (100,000 SGD)
max_drawdown_pct      = 0.15      # 15% MDD limit
risk_per_trade_pct    = 0.01      # Calibrated to 1.0% risk per trade for standard accounts
min_risk_reward_ratio = 1.5       # MINIMUM 1:1.5 risk-reward (Gold volatility demands positive expectancy)
max_slippage_pips     = 5.0       # Gold has wider spreads; 5 pips max slippage tolerance
max_open_positions    = 2         # Maximum concurrent positions
whipsaw_freeze_sec    = 600       # 10-minute freeze after fakeout detection (Gold swings wider)
max_consecutive_losses = 3        # After 3 consecutive losses, freeze trading for loss_streak_freeze_sec
loss_streak_freeze_sec = 1800     # 30-minute freeze after hitting max consecutive losses

# ─── ZeroMQ IPC Configuration ────────────────────────────────────────────────
[zmq]
protocol   = "ipc"                          # "ipc" (recommended) | "tcp"
ipc_path   = "/tmp/quantelos_ipc.sock"      # Unix domain socket path
tcp_addr   = "tcp://127.0.0.1:5555"         # Fallback TCP loopback
timeout_ms = 5000                            # Subscriber poll timeout

# ─── Database Configuration ──────────────────────────────────────────────────
[database]
path         = "./data/quantelos.db"
journal_mode = "WAL"
busy_timeout = 5000

# ─── Technical Analysis Parameters (Gold-Tuned v2.0) ─────────────────────────
[strategy]
name             = "QUANTITATIVE_SNIPER"
timeframe        = "M5"              # Scalping runs on M5 execution timeframe
active_mode      = "MTF_SCALPER"     # "QUANTITATIVE_SNIPER" (legacy M15 breakout/reversion) | "MTF_SCALPER"
atr_period       = 14
atr_squeeze_threshold_pips = 180.0  # Gold's "calm" is ~150-200 pips; below 180 = squeeze
bollinger_period = 20
bollinger_std    = 2.0
bollinger_bandwidth_percentile = 25  # Bandwidth < 25th percentile of 20-day history
rsi_period       = 14
rsi_neutral_low  = 40
rsi_neutral_high = 60
scalping_rsi_low = 40                # Pullback, not capitulation
scalping_rsi_high = 60               # Pullback, not capitulation
scalping_vwap_std = 1.5              # Tighter Keltner so setups appear
scalping_trend_filter = true         # Enforce trend-following trading alignment
allow_asia_scalping = true           # Enable Asia session trading for development
cooldown_sec = 120                   # 2-minute cooldown between scalps
news_block_pre_min = 10              # Block trading 10 minutes before high-impact news
news_block_post_min = 15             # Block trading 15 minutes after high-impact news
scalping_stop_pips = 60.0            # Gold-tuned: $6.00 SL minimum (60 pips × 0.1)
scalping_target_pips = 120.0         # Gold-tuned: $12.00 TP target (120 pips × 0.1)
scalping_atr_tp_mult = 3.0           # 3.0x ATR for TP — let winners run on Gold
scalping_atr_sl_mult = 2.0           # 2.0x ATR for SL — give Gold breathing room
scalping_min_sl_price = 5.0          # Minimum SL distance in price ($5.00 for Gold)
scalping_min_tp_price = 8.0          # Minimum TP distance in price ($8.00 for Gold)
max_spread_pips = 8.0               # Max acceptable spread before blocking entry (Gold: $0.80)
staleness_check_sec = 60             # Re-validate price if AI inference takes >60s


# ─── Market Time Windows (MRD-Locked, WIB / UTC+7) ───────────────────────────
[market_windows]
midnight_block_start = "04:00"    # Hard block: NO new positions
midnight_block_end   = "05:15"
asia_session_start   = "05:00"    # Passive monitoring mode
asia_session_end     = "13:00"
london_session_start = "13:00"    # Active monitoring
london_session_end   = "17:00"
golden_window_start  = "19:00"    # HIGH ALERT execution window
golden_window_end    = "22:00"

# ─── AI Router Configuration (replaces Kaggle) ───────────────────────────────
[kaggle]
sync_method     = "manual"       # "manual" to use the URL below directly
supabase_url    = "https://openrouter.ai" # Or use 9Router: "http://localhost:20128"
router_api_key  = "sk-or-YOUR-OPENROUTER-API-KEY"
target_model    = "nousresearch/hermes-3-llama-3.1-405b:free"  # The monster 405B model
inference_timeout_s = 180          # Max wait for LLM
num_predict     = 4096             # Max response tokens
ollama_num_ctx  = 16384            # Context window size
fallback_model  = "none"           # DISABLED: No VADER fallback for live trading (safety)
min_ai_confidence = 0.60           # DeepSeek-R1 confidence is well-calibrated; 0.60 threshold
block_trade_on_ai_failure = true   # Hard-block trading when AI brain is unreachable

# ─── Notification Channels ───────────────────────────────────────────────────
[notifications]
enabled        = true
discord_webhook = "https://discord.com/api/webhooks/YOUR_WEBHOOK_URL"
telegram_bot_token = "YOUR_TELEGRAM_BOT_TOKEN"
telegram_chat_id   = "YOUR_CHAT_ID"
alert_on_trade     = true
alert_on_error     = true
alert_on_heartbeat_fail = true

# ─── Scraper Configuration ───────────────────────────────────────────────────
[scraper]
layer1_timeout_ms     = 200       # HTTP client max latency
layer2_enabled        = true      # Playwright Stealth fallback
layer2_max_ram_mb     = 400       # cgroup RAM limit for Playwright
layer3_enabled        = false     # CloakBrowser (manual enable only)
layer3_max_ram_mb     = 500       # cgroup RAM limit for CloakBrowser
force_kill_after_s    = 30        # Kill browser process after extraction
sources               = ["forex_factory", "investing_com", "financial_juice"]

# ─── Logging ──────────────────────────────────────────────────────────────────
[logging]
level      = "INFO"               # "DEBUG" | "INFO" | "WARNING" | "ERROR"
log_file   = "./logs/quantelos.log"
max_size_mb = 50
rotate     = true
